#!/usr/bin/env zsh
# cwrm [--on-exit] [--force] <name> — remove the worktree .claude/worktrees/<name>
# (and its branch) from the main checkout.
#
#   default     refuse if the worktree has uncommitted changes OR unpushed
#               commits; pass --force to remove regardless.
#   --on-exit   intended to run right after a Claude session exits (see `cw`).
#               If the worktree is clean AND fully pushed, PROMPT
#               "remove worktree '<name>'? [y/N]"; otherwise keep it silently
#               (never nudges you toward losing work).
#
# Always removes from the main working tree, so it works even though the just-
# exited shell was inside the worktree. Part of warp-worktree.
emulate -L zsh

if [[ "$1" == -h || "$1" == --help ]]; then
  print -r -- 'usage: cwrm [--on-exit] [--force] <name>
  Remove the worktree .claude/worktrees/<name> and its branch.
  Refuses if it has uncommitted or unpushed changes unless --force.
  --on-exit: prompt to remove only if clean + pushed (used by cw on Claude exit).'
  exit 0
fi

local on_exit=0 force=0
while [[ "$1" == -* ]]; do
  case "$1" in
    --on-exit) on_exit=1 ;;
    -f|--force) force=1 ;;
    --) shift; break ;;
    *) print -u2 "cwrm: unknown option $1"; exit 2 ;;
  esac
  shift
done
local name="${1:?usage: cwrm [--on-exit] [--force] <name>}"

local root; root="$(git rev-parse --git-common-dir 2>/dev/null)" || { print -u2 "cwrm: not in a git repo"; exit 1; }
root="${root:A:h}"
local wt="$root/.claude/worktrees/$name"
[[ -d "$wt" ]] || { print -u2 "cwrm: no such worktree: $wt"; exit 1; }

# Safe to remove == nothing would be lost: clean working tree + no unpushed
# commits (measured against the branch's upstream, or origin/HEAD if it has none).
cwrm_safe() {
  [[ -z "$(git -C "$wt" status --porcelain 2>/dev/null)" ]] || return 1
  local ahead
  if git -C "$wt" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
    ahead="$(git -C "$wt" rev-list --count '@{u}..HEAD' 2>/dev/null)" || return 1
  else
    ahead="$(git -C "$wt" rev-list --count 'origin/HEAD..HEAD' 2>/dev/null)" || return 1
  fi
  [[ "$ahead" == 0 ]]
}

local branch; branch="$(git -C "$wt" rev-parse --abbrev-ref HEAD 2>/dev/null)"

cwrm_do() {
  git -C "$root" worktree remove "$wt" --force || return 1
  [[ -n "$branch" && "$branch" != HEAD ]] && git -C "$root" branch -D "$branch" >/dev/null 2>&1
  git -C "$root" worktree prune >/dev/null 2>&1
  print -P "%F{green}✓%f removed worktree %F{cyan}$name%f${branch:+ %F{244}(branch $branch)%f}"
}

if (( on_exit )); then
  cwrm_safe || { print -P "%F{244}•%f keeping %F{cyan}$name%f %F{244}(uncommitted or unpushed changes)%f"; exit 0; }
  if command -v gum >/dev/null 2>&1; then
    # Full TUI confirm (←/→ or y/n), default No.
    if gum confirm --default=false "🧹 ${name} is clean & pushed — remove this worktree?"; then
      cwrm_do
    else
      print -P "%F{244}•%f kept %F{cyan}$name%f"
    fi
  else
    print -Pn "%F{cyan}🧹%f  %F{cyan}$name%f is clean & pushed — remove it? %F{244}[y/N]%f "
    local reply; read -r reply
    if [[ "$reply" == [yY]* ]]; then cwrm_do; else print -P "%F{244}•%f kept %F{cyan}$name%f"; fi
  fi
  exit 0
fi

if (( ! force )) && ! cwrm_safe; then
  print -u2 -P "%F{red}✗%f %F{cyan}$name%f has uncommitted or unpushed changes — use %B--force%b to remove anyway"
  exit 1
fi
cwrm_do
