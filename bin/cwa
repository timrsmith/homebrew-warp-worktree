#!/usr/bin/env zsh
# cwa [name] — open a Warp tab in every .claude/worktrees/* of the current repo
# (or just <name>), each one IN its worktree running Claude (resume its session,
# else fresh), with the same exit-time cleanup prompt as `cw`. Part of
# warp-worktree.
emulate -L zsh

local root; root="$(git rev-parse --git-common-dir 2>/dev/null)" || { print -u2 "cwa: not in a git repo"; exit 1; }
root="${root:A:h}"   # parent of the common .git = main working tree (works from inside a worktree)
local base="$root/.claude/worktrees"
[[ -d "$base" ]] || { print -u2 "cwa: no worktrees under $base"; exit 1; }

# Open one worktree tab: Claude in the worktree + exit-time clean+pushed removal
# prompt (zsh `always` fires it on every exit path).
cwa_open() {
  local wt="$1" name="${1:t}"
  local cmd="{ claude --continue || claude } always { cd ${(q)root} && cwrm --on-exit ${(q)name} }"
  print "cwa: opening $name"
  WARP_HERE_CMD="$cmd" warp-here "$wt"
}

if [[ -n "$1" ]]; then
  local wt="$base/$1"
  [[ -d "$wt" ]] || { print -u2 "cwa: no such worktree: $wt"; exit 1; }
  cwa_open "$wt"
  exit 0
fi

local -a wts=("$base"/*(/N))
(( ${#wts} )) || { print -u2 "cwa: no worktrees found under $base"; exit 1; }
local wt
for wt in $wts; do
  cwa_open "$wt"
done
