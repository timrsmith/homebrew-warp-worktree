#!/usr/bin/env zsh
# cw <name> — open a Warp tab for the worktree <name>.
#
#   • If .claude/worktrees/<name> does NOT exist yet → open a tab at the repo
#     root running `claude --worktree <name>`. Claude creates and OWNS the
#     worktree, so it also cleans it up on exit (keep/remove prompt; clean ones
#     auto-prune) — no manual teardown needed.
#   • If it already exists → just reopen it: a tab in the worktree dir running
#     `claude --continue` (attach = navigate into the dir and launch Claude).
#
# Either way the tab is a classic terminal (see warp-here), not a Warp Agent.
# Part of warp-worktree.
emulate -L zsh

local name="${1:?usage: cw <name>}"

local root; root="$(git rev-parse --git-common-dir 2>/dev/null)" || { print -u2 "cw: not in a git repo"; exit 1; }
root="${root:A:h}"   # parent of the common .git = main working tree (works from inside a worktree)
local wt="$root/.claude/worktrees/$name"

if [[ -d "$wt" ]]; then
  print -u2 "cw: worktree exists — reopening (claude --continue): $wt"
  exec warp-here "$wt"
fi

# Create: let Claude own the worktree's lifecycle. The tab opens at the repo
# root (where --worktree resolves .claude/worktrees/<name>); Claude moves the
# session into the new worktree and removes it on exit if you choose to.
print -u2 "cw: creating worktree via 'claude --worktree $name'"
exec env WARP_HERE_CMD="claude --worktree ${(q)name}" warp-here "$root"
