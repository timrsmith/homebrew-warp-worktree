#!/usr/bin/env zsh
# cw <name> — open a classic Warp tab IN .claude/worktrees/<name> running Claude
# in that worktree (so the Warp tab follows the worktree, single tab, no
# duplicate session). Creates the worktree first if it doesn't exist.
#
# The worktree is created with plain `git worktree add` (NOT `claude --worktree`)
# precisely so it exists before the tab opens and the tab can sit in it. Because
# Claude therefore doesn't own it, cleanup is handled here instead: when you exit
# Claude, you're prompted to remove the worktree IF it's clean + pushed
# (`cwrm --on-exit`). Use `cwsweep` for bulk tidy-up. Part of warp-worktree.
emulate -L zsh

if [[ "$1" == -h || "$1" == --help ]]; then
  print -r -- 'usage: cw <name>
  Open a Warp tab IN .claude/worktrees/<name> running Claude in that worktree
  (creates the worktree if needed). On exit, prompts to remove it if clean + pushed.'
  exit 0
fi

local name="${1:?usage: cw <name>}"

local root; root="$(git rev-parse --git-common-dir 2>/dev/null)" || { print -u2 "cw: not in a git repo"; exit 1; }
root="${root:A:h}"   # parent of the common .git = main working tree (works from inside a worktree)
local wt="$root/.claude/worktrees/$name"

if [[ -d "$wt" ]]; then
  print -u2 "cw: opening existing worktree $name"
else
  print -u2 "cw: creating worktree $name"
  git -C "$root" worktree add "$wt" -b "$name" origin/HEAD || exit 1

  # Plain `git worktree add` makes a clean checkout with no untracked files and
  # doesn't honor .worktreeinclude (that's a Claude-only step). Replicate it:
  # copy gitignored files matching the repo's .worktreeinclude (e.g. .env) into
  # the new worktree, preserving relative paths.
  if [[ -f "$root/.worktreeinclude" ]]; then
    local rel n=0
    while IFS= read -r -d '' rel; do
      git -C "$root" check-ignore -q -- "$rel" || continue   # only gitignored files
      mkdir -p "$wt/${rel:h}"
      cp -p "$root/$rel" "$wt/$rel" && (( n++ ))
    done < <(git -C "$root" ls-files -o -i --exclude-from="$root/.worktreeinclude" -z 2>/dev/null)
    (( n )) && print -u2 "cw: copied $n file(s) per .worktreeinclude"
  fi
fi

# Run Claude in the worktree (resume its session, else fresh). zsh's
# `{ … } always { … }` runs the cleanup on EVERY exit path — /quit, Ctrl-D, or
# Ctrl-C — so the exit-time removal prompt always fires.
local cmd="{ claude --continue || claude } always { cd ${(q)root} && cwrm --on-exit ${(q)name} }"
exec env WARP_HERE_CMD="$cmd" warp-here "$wt"
